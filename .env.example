# Ключ JavaScript API Яндекс.Карт (https://developer.tech.yandex.ru/)
# Укажите ограничение по HTTP Referer: localhost (разработка) и домен продакшена.
NUXT_PUBLIC_YANDEX_MAPS_API_KEY=

# Базовый путь приложения. Для GitHub Pages задайте, например: /avtoweld/
# Для деплоя в подпапку на FTP — тот же baseURL (например /avtoweld/).
# Для сайта в корне домена не задавайте (по умолчанию /).
# NUXT_APP_BASE_URL=/avtoweld/
